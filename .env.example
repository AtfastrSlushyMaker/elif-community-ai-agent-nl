## Base template – copy this to .env and fill in your values
## For local backend use .env.local.example
## For Dockerized agent use .env.docker.example

# Comma-separated list of Groq API keys for automatic rotation on rate-limits.
# The agent tries each key in order; if one hits 429 it moves to the next.
GROQ_API_KEYS=key1,key2,key3

# Single fallback key (used only when GROQ_API_KEYS is empty)
GROQ_API_KEY=replace_with_your_groq_api_key

GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq

BACKEND_BASE_URL=http://localhost:8087/elif
BACKEND_COMMUNITY_PREFIX=/api/community

HTTP_TIMEOUT_SECONDS=30
MAX_AGENT_ACTIONS=6
