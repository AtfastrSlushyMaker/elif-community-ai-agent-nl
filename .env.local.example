# Local runtime – backend runs directly on host
# Copy to .env: cp .env.local.example .env

# Comma-separated Groq API keys for rate-limit rotation
GROQ_API_KEYS=key1,key2,key3
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq

BACKEND_BASE_URL=http://localhost:8087/elif
BACKEND_COMMUNITY_PREFIX=/api/community

HTTP_TIMEOUT_SECONDS=30
MAX_AGENT_ACTIONS=6
