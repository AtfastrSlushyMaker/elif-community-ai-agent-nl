# Docker runtime – agent runs in container, backend on the host machine
# Copy to .env: cp .env.docker.example .env
#
# host.docker.internal resolves to the host on macOS / Windows Docker Desktop.
# On Linux, add --add-host host.docker.internal:host-gateway to docker run.

# Comma-separated Groq API keys for rate-limit rotation
GROQ_API_KEYS=key1,key2,key3
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq

BACKEND_BASE_URL=http://host.docker.internal:8087/elif
BACKEND_COMMUNITY_PREFIX=/api/community

HTTP_TIMEOUT_SECONDS=30
MAX_AGENT_ACTIONS=6
